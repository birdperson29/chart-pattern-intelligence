# Chart Pattern Intelligence — Environment Variables
# Copy this to .env and fill in your keys

# LLM for plain-English explanations (pick one)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLM_PROVIDER=anthropic  # or "openai"

# News API (optional — for sentiment layer)
NEWS_API_KEY=your-newsapi-key

# Reddit (optional — for social sentiment)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-secret

# Twitter/X (optional)
TWITTER_BEARER_TOKEN=your-twitter-bearer

# App settings
APP_PORT=8000
STREAMLIT_PORT=8501
CACHE_TTL_MINUTES=15
